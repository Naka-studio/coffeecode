        <aapt:attr name="android:animation">
            <set>
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.6"
                    android:valueTo="1"
                    android:duration="500"
                    android:interpolator="@android:interpolator/overshoot"/>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.6"
                    android:valueTo="1"
                    android:duration="500"
                    android:interpolator="@android:interpolator/overshoot"/>
            </set>
        </aapt:attr>
    </target>

    <target android:name="blue">
        <aapt:attr name="android:animation">
            <set android:startOffset="150">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.6"
                    android:valueTo="1"
                    android:duration="500"
                    android:interpolator="@android:interpolator/overshoot"/>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.6"
                    android:valueTo="1"
                    android:duration="500"
                    android:interpolator="@android:interpolator/overshoot"/>
            </set>
        </aapt:attr>
    </target>

    <target android:name="orange">
        <aapt:attr name="android:animation">
            <set android:startOffset="300">
                <objectAnimator
                    android:propertyName="scaleX"
                    android:valueFrom="0.6"
                    android:valueTo="1"
                    android:duration="500"
                    android:interpolator="@android:interpolator/overshoot"/>
                <objectAnimator
                    android:propertyName="scaleY"
                    android:valueFrom="0.6"
                    android:valueTo="1"
                    android:duration="500"
                    android:interpolator="@android:interpolator/overshoot"/>
            </set>
        </aapt:attr>
    </target>

</animated-vector>